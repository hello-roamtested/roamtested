---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import ScoreCard from '../components/ScoreCard.astro';
import AppAccessMatrix from '../components/AppAccessMatrix.astro';
import SpeedTable from '../components/SpeedTable.astro';
import ThrottleCard from '../components/ThrottleCard.astro';
import ProsCons from '../components/ProsCons.astro';
import SampleBanner from '../components/SampleBanner.astro';
import AffiliateButton from '../components/AffiliateButton.astro';
import ReviewSchema from '../components/ReviewSchema.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/^en\//, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// review 文章:拉取对应 provider 的结构化数据
const provider = post.data.provider ? await getEntry('providers', post.data.provider) : null;

// roundup 文章:插入完整对比表
const isRoundup = post.data.kind === 'roundup';
const providers = isRoundup
  ? (await getCollection('providers')).filter((p) => p.data.listed && p.data.lang === 'en')
  : [];

const showSample =
  (provider && provider.data.sampleData) || providers.some((p) => p.data.sampleData);

// 存证标签:取最近一次测速的城市与日期
function evidenceChip(p: any): string | undefined {
  const tests = p?.data?.speedTests;
  if (!tests || tests.length === 0) return undefined;
  const latest = [...tests].sort((a, b) => b.date.localeCompare(a.date))[0];
  return `Tested ${latest.city} · ${latest.date}`;
}
---

<Base title={post.data.title} description={post.data.description}>
  <article class="wrap">
    <header class="post-head">
      <h1>{post.data.title}</h1>
      <p class="muted">{post.data.description}</p>
      <p>
        <span class="chip">Published {post.data.date}</span>
        {post.data.updated && <span class="chip">Updated {post.data.updated}</span>}
      </p>
    </header>

    {showSample && <SampleBanner />}

    {isRoundup && (
      <section class="data-block">
        <ComparisonTable providers={providers} />
      </section>
    )}

    {provider && <ReviewSchema provider={provider} post={post} />}
    {provider && <ScoreCard provider={provider} />} 

    <div class="prose">
      <Content />
    </div>

    {provider && (
      <section class="data-block">
        {provider.data.appAccess && (
          <AppAccessMatrix items={provider.data.appAccess} chip={evidenceChip(provider)} />
        )}
        {provider.data.speedTests && <SpeedTable tests={provider.data.speedTests} />}
        {provider.data.throttlePolicy && <ThrottleCard policy={provider.data.throttlePolicy} />}
        <ProsCons pros={provider.data.pros} cons={provider.data.cons} />
        <p>
          <AffiliateButton
            href={provider.data.affiliateUrl}
            label={`Check ${provider.data.name} plans`}
          />
        </p>
      </section>
    )}
  </article>
</Base>

<style>
  .post-head { padding-top: 2rem; max-width: 44rem; }
  .post-head .chip { margin-right: 0.4rem; }
  .data-block { margin: 2rem 0; }
</style>
